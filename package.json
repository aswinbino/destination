{
  "name": "destination-root",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "app-next"
  ],
  "scripts": {
    "setup": "npm install && cd client && npm install && cd ../server && npm install && cd ../app-next && npm install",
    "client:build": "cd client && npm run build",
    "app-next:build": "cd app-next && npm run build",
    "vercel-build": "npm run client:build"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1"
  }
}
